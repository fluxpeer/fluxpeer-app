<?xml version="1.0" encoding="utf-8"?>
<!-- fluxpeer splash: dark-indigo brand background + centered mesh mark (shared by
     light + night, since the brand identity is indigo-on-dark). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/fluxpeer_splash" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash_logo" />
    </item>
</layer-list>
